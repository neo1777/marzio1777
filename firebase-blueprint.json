{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of Marzio Memories",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["Root", "Admin", "Guest"] },
        "points": { "type": "number" },
        "shareLiveLocation": { "type": "boolean" },
        "apiKey": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "UserLocation": {
      "title": "UserLocation",
      "description": "Public volatile location data for map",
      "type": "object",
      "properties": {
         "userId": { "type": "string" },
         "displayName": { "type": "string" },
         "photoURL": { "type": "string" },
         "shareLiveLocation": { "type": "boolean" },
         "liveLocation": {
            "type": "object",
            "properties": {
               "lat": { "type": "number" },
               "lng": { "type": "number" },
               "updatedAt": { "type": "object" }
            }
         }
      },
      "required": ["userId"]
    },
    "Post": {
      "title": "Post",
      "description": "A memory photo post or text post",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "location": {
           "type": "object",
           "properties": {
             "lat": { "type": "number" },
             "lng": { "type": "number" }
           }
        },
        "decade": { "type": "string" },
        "timestamp": { "type": "object" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "visibilityStatus": { "type": "string", "enum": ["public", "private", "scheduled"] },
        "visibilityTime": { "type": "number" },
        "showInCinematografo": { "type": "boolean" }
      },
      "required": ["authorId", "authorName", "timestamp", "likesCount", "commentsCount", "visibilityStatus"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["postId", "authorId", "authorName", "text", "timestamp"]
    },
    "Event": {
      "title": "Event",
      "description": "Community event in Il Bivacco",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["authorId", "authorName", "name", "date", "timestamp"]
    },
    "EventItem": {
      "title": "EventItem",
      "description": "Checklist item",
      "type": "object",
      "properties": {
         "text": { "type": "string" },
         "assignedTo": { "type": "string" },
         "assignedName": { "type": "string" }
      },
      "required": ["text"]
    },
    "EventExpense": {
      "title": "EventExpense",
      "description": "Expense item",
      "type": "object",
      "properties": {
         "description": { "type": "string" },
         "amount": { "type": "number" },
         "paidBy": { "type": "string" },
         "paidByName": { "type": "string" }
      },
      "required": ["description", "amount", "paidBy", "paidByName"]
    },
    "ChatChannel": {
      "title": "ChatChannel",
      "description": "A chat channel in L Alberone",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["name", "createdBy"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in a chat channel",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["authorId", "authorName", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User private profiles (PII)"
    },
    "/user_locations/{userId}": {
      "schema": { "$ref": "#/entities/UserLocation" },
      "description": "Public location data"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Memory posts"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on a post"
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Events"
    },
    "/events/{eventId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/EventItem" },
      "description": "Event logistics items"
    },
    "/events/{eventId}/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/EventExpense" },
      "description": "Event expenses"
    },
    "/chats/{channelId}": {
      "schema": { "$ref": "#/entities/ChatChannel" },
      "description": "Chat channels"
    },
    "/chats/{channelId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Messages inside a channel"
    }
  }
}
