rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} { 
      allow read, write: if false; 
    }

    // --- PRIMITIVES ---
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isRoot() { return isSignedIn() && request.auth.token.email == 'nicolainformatica@gmail.com'; }
    function isAdminOrRoot() { 
        return isRoot() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountStatus == 'approved' &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Root']); 
    }
    function isOwner(authorId) { return isSignedIn() && request.auth.uid == authorId; }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isApprovedUser() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserDoc().accountStatus == 'approved';
    }
    function getEventDoc(eventId) {
      return get(/databases/$(database)/documents/game_events/$(eventId)).data;
    }
    function isEventOrganizer(eventId) {
      return isSignedIn() && getEventDoc(eventId).organizerId == request.auth.uid;
    }
    function isCurrentHost(eventId) {
      return isSignedIn() && getEventDoc(eventId).get('photoQuizConfig', {}).get('currentHostId', null) == request.auth.uid;
    }
    function isEventActive(eventId) {
      return getEventDoc(eventId).status == 'active';
    }
    function isEventParticipant(eventId) {
      return exists(/databases/$(database)/documents/game_events/$(eventId)/participants/$(request.auth.uid))
        && get(/databases/$(database)/documents/game_events/$(eventId)/participants/$(request.auth.uid)).data.status == 'joined';
    }
    function isWithinTimeWindow(eventId) {
      let ev = getEventDoc(eventId);
      return request.time >= ev.scheduledKickoff && request.time <= (ev.endTime != null ? ev.endTime : timestamp.date(2099, 1, 1));
    }

    // --- VALIDATORS ---
    function isValidUser(data) {
       return data.keys().hasAll(['uid', 'email', 'role', 'accountStatus']) &&
              data.uid is string && data.uid.size() <= 128 &&
              data.email is string && data.email.size() <= 200 &&
              data.role in ['Root', 'Admin', 'Guest'] &&
              data.accountStatus in ['pending', 'approved'] &&
              data.uid == request.auth.uid; // Identity verify
    }

    function isValidUserLocation(data) {
       return data.keys().hasAll(['userId', 'shareLiveLocation']) &&
              data.userId == request.auth.uid &&
              data.shareLiveLocation is bool;
    }

    function isValidPost(data) {
       return data.keys().hasAll(['authorId', 'authorName', 'timestamp', 'likesCount', 'commentsCount', 'visibilityStatus']) &&
              data.authorId == request.auth.uid && 
              data.authorName is string && data.authorName.size() <= 100 &&
              data.likesCount is number && data.commentsCount is number &&
              data.get('likedBy', []) is list && data.get('likedBy', []).size() <= 5000 &&
              data.visibilityStatus in ['public', 'private', 'scheduled'];
    }

    function isValidComment(data) {
       return data.keys().hasAll(['postId', 'authorId', 'authorName', 'text', 'timestamp']) &&
              data.authorId == request.auth.uid &&
              data.text is string && data.text.size() > 0 && data.text.size() <= 2000 &&
              data.postId is string && data.postId.size() <= 128;
    }

    function isValidEvent(data) {
       return data.keys().hasAll(['authorId', 'authorName', 'name', 'date', 'timestamp']) &&
              data.authorId == request.auth.uid &&
              data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
              data.date is string && data.date.size() <= 50;
    }

    function isValidEventItem(data) {
       return data.keys().hasAll(['text']) &&
              data.text is string && data.text.size() > 0 && data.text.size() <= 300;
    }

    function isValidEventExpense(data) {
       return data.keys().hasAll(['description', 'amount', 'paidBy', 'paidByName']) &&
              data.description is string && data.description.size() > 0 && data.description.size() <= 300 &&
              data.amount is number && 
              data.paidBy == request.auth.uid &&
              data.paidByName is string && data.paidByName.size() <= 100;
    }

    function isValidChatChannel(data) {
       return data.keys().hasAll(['name', 'createdBy']) &&
              data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
              data.createdBy == request.auth.uid;
    }

    function isValidChatMessage(data) {
       return data.keys().hasAll(['authorId', 'authorName', 'text', 'timestamp']) &&
              data.authorId == request.auth.uid &&
              data.text is string && data.text.size() > 0 && data.text.size() <= 2000;
    }

    // --- RULES ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdminOrRoot());
      allow list: if isSignedIn() && isAdminOrRoot();
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming()) && incoming().role == (isRoot() ? 'Root' : 'Guest') && incoming().accountStatus == (isRoot() ? 'approved' : 'pending');
      allow update: if isSignedIn() && isValidUser(incoming()) && (
         (request.auth.uid == userId && (
            incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'apiKey', 'shareLiveLocation', 'animIcon', 'animSpeed', 'animDistance', 'animColor']) &&
            incoming().role == existing().role &&
            incoming().accountStatus == existing().accountStatus &&
            incoming().points == existing().points
         )) ||
         // Monotonic owner-side points increment: lets the client commit
         // gamification rewards (capture, quiz self-claim, +2 audio play,
         // +5 DJ base, +10 DJ long-session) bounded to 1000/transaction.
         // Cap sized to cover worst-case (item × 5x multiplier ≈ 5000 is
         // impossible because items.update writes points × eventMultiplier
         // and the linked event's pointsMultiplier is rule-bounded to 5.0,
         // while item.points are practically ≤ 200). The 1000 cap blocks
         // catastrophic forging (`points: 9999999`) while leaving room for
         // legitimate rewards. Real anti-cheat lives in the rule of the
         // action that earned the points (items.update, answers.update,
         // queue.update — each independently validates correctness).
         (request.auth.uid == userId &&
          incoming().diff(existing()).affectedKeys().hasOnly(['points', 'updatedAt']) &&
          incoming().points is number && existing().points is number &&
          incoming().points >= existing().points &&
          incoming().points - existing().points <= 1000) ||
         (isRoot() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'accountStatus'])) ||
         (isAdminOrRoot() && !isRoot() && existing().role != 'Root' && incoming().role != 'Root' && (
            // Admin can approve pending to Guest
            (existing().accountStatus == 'pending' && incoming().accountStatus == 'approved' && incoming().role == 'Guest' && incoming().diff(existing()).affectedKeys().hasOnly(['accountStatus', 'role', 'updatedAt'])) ||
            // Admin can promote Guest to Admin
            (existing().accountStatus == 'approved' && existing().role == 'Guest' && incoming().role == 'Admin' && incoming().accountStatus == 'approved' && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt']))
         ))
      );
      allow delete: if isRoot();
    }

    match /user_locations/{userId} {
      allow get: if isSignedIn() && isAdminOrRoot() && (resource.data.shareLiveLocation == true || request.auth.uid == userId);
      // Client explicitly MUST filter by shareLiveLocation == true
      allow list: if isSignedIn() && isAdminOrRoot() && resource.data.shareLiveLocation == true;
      allow create: if isSignedIn() && isAdminOrRoot() && isValidId(userId) && isValidUserLocation(incoming());
      allow update: if isSignedIn() && isAdminOrRoot() && isValidUserLocation(incoming()) && request.auth.uid == userId && (
         incoming().diff(existing()).affectedKeys().hasOnly(['shareLiveLocation', 'liveLocation', 'displayName', 'photoURL', 'updatedAt'])
      );
    }

    match /posts/{postId} {
      allow get: if isSignedIn() && isAdminOrRoot() && (
         resource.data.visibilityStatus in ['public', 'scheduled'] || 
         resource.data.authorId == request.auth.uid || 
         isAdminOrRoot()
      );
      // Client MUST query explicitly with visibilityStatus in [...] or authorId == request.auth.uid
      // Note: We use client-side filtering for visibilityTime to avoid multiple-range-index database limitations
      allow list: if isSignedIn() && isAdminOrRoot() && (
         resource.data.visibilityStatus in ['public', 'scheduled'] || 
         resource.data.authorId == request.auth.uid
      );
      allow create: if isSignedIn() && isAdminOrRoot() && isValidId(postId) && isValidPost(incoming()) && incoming().likesCount == 0 && incoming().commentsCount == 0 && incoming().get('likedBy', []).size() == 0;
      allow update: if isSignedIn() && isAdminOrRoot() && isValidPost(incoming()) && (
         isAdminOrRoot() || (
            request.auth.uid == existing().authorId &&
            incoming().diff(existing()).affectedKeys().hasOnly(['caption', 'location', 'decade', 'visibilityStatus', 'visibilityTime', 'showInCinematografo'])
         ) || (
            // Anyone (approved) can like/unlike or bump comments — granular updates.
            // Sporca #31 "Like Forger": before this hardening the rule only
            // checked `likedBy.size + 1 == likesCount + 1`, which a malicious
            // caller could satisfy by appending some-other-uid to `likedBy`.
            // The set diff below pins the new/removed element to the caller.
            (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'likedBy']) &&
             (
               // Like: incoming.likedBy = existing.likedBy ∪ {auth.uid},
               //       likesCount += 1, and auth.uid wasn't in the old set.
               (incoming().likesCount == existing().likesCount + 1 &&
                incoming().get('likedBy', []).size() == existing().get('likedBy', []).size() + 1 &&
                incoming().get('likedBy', []).toSet().difference(existing().get('likedBy', []).toSet()).hasOnly([request.auth.uid]) &&
                !(request.auth.uid in existing().get('likedBy', []))
               ) ||
               // Unlike: incoming.likedBy = existing.likedBy \ {auth.uid},
               //         likesCount -= 1, and auth.uid was in the old set.
               (incoming().likesCount == existing().likesCount - 1 &&
                incoming().get('likedBy', []).size() == existing().get('likedBy', []).size() - 1 &&
                existing().get('likedBy', []).toSet().difference(incoming().get('likedBy', []).toSet()).hasOnly([request.auth.uid]) &&
                request.auth.uid in existing().get('likedBy', [])
               )
             )
            ) ||
            (incoming().diff(existing()).affectedKeys().hasOnly(['commentsCount']) &&
             (incoming().commentsCount == existing().commentsCount + 1 || incoming().commentsCount == existing().commentsCount - 1)
            )
         )
      );
      allow delete: if isSignedIn() && isAdminOrRoot() && (request.auth.uid == resource.data.authorId || isAdminOrRoot());

      match /comments/{commentId} {
        allow read: if isSignedIn() && isAdminOrRoot() && (get(/databases/$(database)/documents/posts/$(postId)).data.visibilityStatus in ['public', 'scheduled'] || get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid);
        allow create: if isSignedIn() && isAdminOrRoot() && isValidId(commentId) && isValidComment(incoming());
        allow update: if isSignedIn() && isAdminOrRoot() && isValidComment(incoming()) && request.auth.uid == existing().authorId && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'timestamp']);
        allow delete: if isSignedIn() && isAdminOrRoot() && (request.auth.uid == resource.data.authorId || isAdminOrRoot());
      }
    }

    match /events/{eventId} {
      allow read: if isSignedIn() && isAdminOrRoot();
      allow create: if isSignedIn() && isAdminOrRoot() && isValidId(eventId) && isValidEvent(incoming());
      allow update: if isSignedIn() && isAdminOrRoot() && isValidEvent(incoming()) && (
         isAdminOrRoot() || (
            request.auth.uid == existing().authorId &&
            incoming().diff(existing()).affectedKeys().hasOnly(['name', 'date', 'location', 'description'])
         )
      );
      allow delete: if isSignedIn() && isAdminOrRoot() && (request.auth.uid == resource.data.authorId || isAdminOrRoot());

      match /items/{itemId} {
        allow read: if isSignedIn() && isAdminOrRoot();
        allow create: if isSignedIn() && isAdminOrRoot() && isValidId(itemId) && isValidEventItem(incoming());
        allow update: if isSignedIn() && isAdminOrRoot() && isValidEventItem(incoming()) && (
           incoming().diff(existing()).affectedKeys().hasOnly(['text', 'assignedTo', 'assignedName', 'checked'])
        );
        allow delete: if isSignedIn() && isAdminOrRoot();
      }

      match /expenses/{expenseId} {
        allow read: if isSignedIn() && isAdminOrRoot();
        allow create: if isSignedIn() && isAdminOrRoot() && isValidId(expenseId) && isValidEventExpense(incoming());
        allow update: if isSignedIn() && isAdminOrRoot() && isValidEventExpense(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['description', 'amount', 'paidBy', 'paidByName']);
        allow delete: if isSignedIn() && isAdminOrRoot() && (request.auth.uid == resource.data.paidBy || isAdminOrRoot());
      }
    }

    match /chats/{channelId} {
      allow read: if isSignedIn() && isAdminOrRoot(); // Assume chats are public to registered users
      allow create: if isSignedIn() && isAdminOrRoot() && isValidId(channelId) && isValidChatChannel(incoming());
      allow update: if isAdminOrRoot();
      allow delete: if isAdminOrRoot();

      match /messages/{messageId} {
        allow read: if isSignedIn() && isAdminOrRoot();
        allow create: if isSignedIn() && isAdminOrRoot() && isValidId(messageId) && isValidChatMessage(incoming());
        allow update: if false; // Messages are immutable
        allow delete: if isAdminOrRoot() || (isSignedIn() && isAdminOrRoot() && request.auth.uid == resource.data.authorId);
      }
    }

    match /game_events/{eventId} {
      allow read: if isAdminOrRoot() || isEventParticipant(eventId) || isApprovedUser();

      allow create: if isAdminOrRoot()
        && request.resource.data.organizerId == request.auth.uid
        && request.resource.data.status == 'draft'
        && request.resource.data.type in ['treasure_hunt', 'photo_quiz']
        && request.resource.data.title.size() <= 100
        && request.resource.data.description.size() <= 500
        && request.resource.data.pointsMultiplier >= 0.5
        && request.resource.data.pointsMultiplier <= 5.0
        && request.resource.data.invitedUserIds.size() <= 100
        && request.resource.data.scheduledKickoff > request.time;

      allow update: if (
          (isEventOrganizer(eventId) || isRoot()) 
          || (
            isSignedIn() && resource.data.get('photoQuizConfig', {}).get('currentHostId', null) == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoQuizConfig'])
            && request.resource.data.photoQuizConfig.diff(resource.data.photoQuizConfig).affectedKeys().hasOnly(['currentHostId'])
            && exists(/databases/$(database)/documents/game_events/$(eventId)/participants/$(request.resource.data.photoQuizConfig.currentHostId))
            && get(/databases/$(database)/documents/game_events/$(eventId)/participants/$(request.resource.data.photoQuizConfig.currentHostId)).data.status == 'joined'
          )
        )
        && validStatusTransition(resource.data.status, request.resource.data.status)
        && request.resource.data.organizerId == resource.data.organizerId
        && request.resource.data.type == resource.data.type
        && request.resource.data.createdAt == resource.data.createdAt
        && (resource.data.status != 'completed' || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['finalLeaderboard']));

      allow delete: if isRoot() && resource.data.status != 'active';

      function validStatusTransition(oldStatus, newStatus) {
        return (oldStatus == 'draft' && newStatus in ['draft', 'scheduled', 'aborted'])
          || (oldStatus == 'scheduled' && newStatus in ['scheduled', 'lobby', 'active', 'aborted'])
          || (oldStatus == 'lobby' && newStatus in ['lobby', 'active', 'aborted'])
          || (oldStatus == 'active' && newStatus in ['active', 'completed', 'aborted'])
          || oldStatus == newStatus;
      }

      match /items/{itemId} {
        allow read: if isAdminOrRoot() || isEventParticipant(eventId) || isApprovedUser();
        // Bound `points` to [1, 200]: a capture writes
        // `users/{uid}.points += points × pointsMultiplier`, and the
        // `users.update` rule caps the per-transaction increment at +1000.
        // With multiplier_max = 5.0, items.points must stay ≤ 200 or a
        // legitimate worst-case capture rolls back at the rule layer.
        allow create: if (isEventOrganizer(eventId) || isAdminOrRoot())
          && getEventDoc(eventId).status in ['draft', 'scheduled']
          && request.resource.data.status == 'spawned'
          && request.resource.data.collectedBy == null
          && request.resource.data.points is int
          && request.resource.data.points >= 1
          && request.resource.data.points <= 200;

        // Item capture (transition 'spawned' → 'collected'). Two paths:
        // (1) legacy fast-path — kept for backward compat with clients that
        //     don't yet call the validateCaptureDistance Cloud Function.
        //     Audit log via collectedAtLat/Lng. Tolerated for the
        //     community-trust threat model, replaced by path (2) below.
        // (2) server-validated path — closes Sporca #14 The Teleporter.
        //     The CF wrote `serverValidatedAt` ≤ 30s ago after running a
        //     server-side Haversine; the rule trusts that stamp here.
        allow update: if isEventParticipant(eventId)
          && isEventActive(eventId)
          && isWithinTimeWindow(eventId)
          && resource.data.status == 'spawned'
          && request.resource.data.status == 'collected'
          && request.resource.data.collectedBy == request.auth.uid
          && request.resource.data.lat == resource.data.lat
          && request.resource.data.lng == resource.data.lng
          && request.resource.data.points == resource.data.points
          && request.resource.data.templateId == resource.data.templateId
          && (request.resource.data.get('collectedAtLat', null) == null || request.resource.data.collectedAtLat is number)
          && (request.resource.data.get('collectedAtLng', null) == null || request.resource.data.collectedAtLng is number)
          && request.resource.data.collectedAt == request.time
          && (
              // Path (2): server-validated. The CF stamped validation
              // within the last 30 seconds — accept the capture.
              (resource.data.get('serverValidatedAt', null) is timestamp
               && (request.time.toMillis() - resource.data.serverValidatedAt.toMillis()) < 30000)
              ||
              // Path (1): legacy fast-path. No serverValidatedAt yet on
              // this item; audit log is the only mitigation. Phased out
              // when all clients ship with the CF wiring.
              (resource.data.get('serverValidatedAt', null) == null)
          );

        allow delete: if (isEventOrganizer(eventId) || isRoot())
          && getEventDoc(eventId).status in ['draft', 'scheduled', 'aborted'];
      }

      match /participants/{userId} {
        allow read: if isApprovedUser();

        allow create: if isApprovedUser()
          && userId == request.auth.uid;

        allow update: if userId == request.auth.uid
          && request.resource.data.userId == userId
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'respondedAt', 'shareLocationDuringEvent', 'leftAt']);

        // Self-leave or organizer/Root cleanup (e.g. kick a misbehaving
        // participant). Plain "approved user can delete anyone" was too
        // permissive and would have let a third party erase rivals from
        // the participants list.
        allow delete: if userId == request.auth.uid
          || isEventOrganizer(eventId)
          || isRoot();
      }

      match /leaderboard/{userId} {
        allow read: if isApprovedUser();
        // Self-write (the player's own row), organizer or Root.
        // Pre-fix any participant could rewrite anyone else's leaderboard
        // entry; a malicious player could zero out a rival's score.
        // Note: capture transactions write `leaderboard/{auth.uid}` from
        // the player's own client, so the self-branch is the hot path.
        allow write: if isApprovedUser()
          && getEventDoc(eventId).status != 'completed'
          && (
              userId == request.auth.uid
              || isEventOrganizer(eventId)
              || isRoot()
          );
      }

      match /quizRounds/{roundId} {
        allow read: if isEventParticipant(eventId);
        allow create: if (isCurrentHost(eventId) || isEventOrganizer(eventId) || isRoot()) && isEventActive(eventId);
        allow update: if (isCurrentHost(eventId) || isEventOrganizer(eventId) || isRoot())
          && resource.data.revealedAt == null
          && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['revealedAt', 'correctIndex', 'status', 'winnerId']));

        match /secret/{docId} {
          allow read: if (isCurrentHost(eventId) || isEventOrganizer(eventId) || isRoot());
          allow create, update: if (isCurrentHost(eventId) || isEventOrganizer(eventId) || isRoot()) && docId == 'correctness';
        }

        match /answers/{answerUserId} {
          allow read: if isEventParticipant(eventId)
            && get(/databases/$(database)/documents/game_events/$(eventId)/quizRounds/$(roundId)).data.revealedAt != null;
            
          allow create: if answerUserId == request.auth.uid
            && isEventParticipant(eventId)
            && request.resource.data.userId == answerUserId
            && request.time < get(/databases/$(database)/documents/game_events/$(eventId)/quizRounds/$(roundId)).data.endsAt
            && request.resource.data.selectedIndex >= 0
            && request.resource.data.selectedIndex <= 3;
            
          // Owner-side self-claim post-reveal (preferred) OR host triade
          // override. Anti-cheat is identical for both paths: the rule
          // re-derives the correct outcome from `correctIndex` (publicly
          // readable post-reveal) and caps `pointsAwarded` to the
          // event-configured maximum scaled by the multiplier.
          allow update: if (
                (answerUserId == request.auth.uid && isEventParticipant(eventId))
                || isCurrentHost(eventId) || isEventOrganizer(eventId) || isRoot()
              )
            && get(/databases/$(database)/documents/game_events/$(eventId)/quizRounds/$(roundId)).data.revealedAt != null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pointsAwarded'])
            && request.resource.data.pointsAwarded >= 0
            && request.resource.data.pointsAwarded <= (
                 getEventDoc(eventId).get('photoQuizConfig', {}).get('maxPointsPerRound', 100)
                 * getEventDoc(eventId).get('pointsMultiplier', 1)
               )
            && (
              request.resource.data.pointsAwarded == 0
              ||
              (resource.data.selectedIndex == get(/databases/$(database)/documents/game_events/$(eventId)/quizRounds/$(roundId)).data.correctIndex)
            )
            && resource.data.timestamp <= get(/databases/$(database)/documents/game_events/$(eventId)/quizRounds/$(roundId)).data.endsAt;
          allow delete: if false;
        }
      }
    }

    // --- AUDIT LOG ---
    // Written exclusively by Cloud Functions (admin SDK bypasses rules).
    // Read access restricted to Root for forensic review of capture
    // anomalies, mass-skip incidents, etc. Phase 2 §15.A.
    match /audit_log/{logId} {
      allow read: if isRoot();
      allow write: if false; // CF-only via admin SDK
    }

    // --- AINULINDALE HELPERS ---
    function isSessionDJ(sessionId) {
      return isSignedIn() && get(/databases/$(database)/documents/audio_sessions/$(sessionId)).data.djId == request.auth.uid;
    }
    function isSessionParticipant(sessionId) {
      return exists(/databases/$(database)/documents/audio_sessions/$(sessionId)/participants/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/audio_sessions/$(sessionId)/participants/$(request.auth.uid)).data.status == 'joined';
    }
    function validQueueStatusTransition(oldStatus, newStatus) {
      // Tightened to the spec'd flow: queued must go through 'transferring'
      // before reaching 'ready'/'failed' (no shortcut). 'failed → skipped'
      // is the cleanup path the engine uses to drop a transfer that errored.
      return (oldStatus == 'queued' && newStatus in ['transferring', 'skipped']) ||
             (oldStatus == 'transferring' && newStatus in ['ready', 'failed']) ||
             (oldStatus == 'ready' && newStatus in ['playing', 'skipped']) ||
             (oldStatus == 'playing' && newStatus in ['played', 'skipped']) ||
             (oldStatus == 'failed' && newStatus == 'skipped') ||
             oldStatus == newStatus;
    }
    function isValidAudioSession(data) {
      return data.keys().hasAll(['djId', 'title', 'status', 'mode', 'rules']) &&
             data.status in ['open', 'closed'] &&
             data.mode in ['auto', 'manual'];
    }
    function isValidQueueItem(data) {
      return data.keys().hasAll(['proposedBy', 'trackTitle', 'trackDurationMs', 'status']);
    }
    // Mirror of getMaxQueuedFor() in src/hooks/useAudioQueue.ts. Returns the
    // server-computed bonus cap for the calling user. Caller-side document count
    // is enforced by the client; per-user count enforcement requires Cloud
    // Functions (Phase 2 — see MIGRATION.md).
    function effectiveMaxQueued(sessionId) {
      let session = get(/databases/$(database)/documents/audio_sessions/$(sessionId)).data;
      let userPoints = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('points', 0);
      return session.rules.maxQueuedPerUser + (int(userPoints / 100) * session.rules.bonusPerHundredPoints);
    }

    // --- AINULINDALE RULES ---
    match /audio_sessions/{sessionId} {
      allow read: if isApprovedUser();
      allow create: if isSignedIn() && isAdminOrRoot() && isValidAudioSession(incoming()) && incoming().djId == request.auth.uid && incoming().status == 'open';
      allow update: if isSessionDJ(sessionId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'mode', 'currentQueueItemId', 'currentTrackTitle', 'currentTrackArtist', 'currentTrackDurationMs', 'currentTrackStartedAt', 'queuedCount', 'playedCount', 'participantCount', 'finalStats', 'closedAt', 'djBonusAwarded']) &&
                    (existing().status == 'open') &&
                    (!incoming().diff(existing()).affectedKeys().hasAny(['djId', 'rules', 'createdAt'])) &&
                    // djBonusAwarded is one-way: false -> true, never revertible.
                    (!incoming().diff(existing()).affectedKeys().hasAny(['djBonusAwarded']) ||
                     (existing().get('djBonusAwarded', false) == false && incoming().djBonusAwarded == true));
      allow delete: if isRoot();

      match /queue/{itemId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser() && isSessionParticipant(sessionId) &&
                      incoming().proposedBy == request.auth.uid &&
                      isValidQueueItem(incoming()) &&
                      incoming().status == 'queued' &&
                      get(/databases/$(database)/documents/audio_sessions/$(sessionId)).data.status == 'open' &&
                      incoming().effectiveMaxAtCreate is int &&
                      incoming().effectiveMaxAtCreate == effectiveMaxQueued(sessionId);
                      
        // Theme Hijacker (Sporca #25/#26): metadata are immutable after create.
        // Only the DJ can mutate, and only the listed mutable fields. Track
        // metadata, proposedBy, localTrackId, proposedAt, position guards
        // (… well: position is still mutable, the DJ may re-order the
        // queue) and effectiveMaxAtCreate are all forbidden post-create.
        allow update: if isSessionDJ(sessionId)
                      && validQueueStatusTransition(existing().status, incoming().status)
                      && incoming().diff(existing()).affectedKeys()
                          .hasOnly([
                            'status', 'position',
                            'transferStartedAt', 'transferCompletedAt', 'transferFailureReason',
                            'pointsAwarded'
                          ])
                      // Defense in depth: even though affectedKeys above already
                      // refuses metadata writes, re-assert the key invariants
                      // explicitly so a future affectedKeys-relaxation can't
                      // silently re-open the hijack vector.
                      && incoming().proposedBy == existing().proposedBy
                      && incoming().localTrackId == existing().localTrackId
                      && incoming().trackTitle == existing().trackTitle
                      && incoming().trackArtist == existing().trackArtist
                      && incoming().trackDurationMs == existing().trackDurationMs
                      // pointsAwarded bounded; matches DJEngine.markCurrentPlayed
                      // upper bound (BASE × 5x multiplier = 10) with margin.
                      && (!incoming().diff(existing()).affectedKeys().hasAny(['pointsAwarded'])
                          || (incoming().pointsAwarded >= 0 && incoming().pointsAwarded <= 50));
        allow delete: if (isSessionDJ(sessionId) || (existing().proposedBy == request.auth.uid && existing().status == 'queued'));
      }

      match /participants/{userId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser() && userId == request.auth.uid &&
                      get(/databases/$(database)/documents/audio_sessions/$(sessionId)).data.status == 'open';
        allow update: if userId == request.auth.uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['lastSeenAt', 'status', 'leftAt', 'tracksProposed', 'tracksPlayed']);
        allow delete: if isRoot();
      }

      // Sub-collection: WebRTC signaling between proposer and DJ.
      // sessionId is implicit in the path; only the doc owner (proposer)
      // and the session DJ can read/write. Mitigates Sporca #30.
      match /signaling/{userId} {
        allow read, create, update, delete: if isApprovedUser() && (
           userId == request.auth.uid ||
           isSessionDJ(sessionId)
        );
      }
    }
  }
}
